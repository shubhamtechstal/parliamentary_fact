    "@hookform/resolvers": "^3.3.2",
    "@mui/icons-material": "^5.14.19",
    "@mui/material": "^5.15.20",
    "@mui/x-data-grid": "^6.18.4",
    "@reduxjs/toolkit": "^2.0.1",
    "axios": "^1.6.2",
    "localforage": "^1.10.0",
    "lodash.get": "^4.4.2",
    "match-sorter": "^6.3.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.49.0",
    "react-redux": "^9.0.3",
    "react-router-dom": "^6.20.1",
    "redux-persist": "^6.0.0",
    "sort-by": "^1.2.0",
    "yup": "^1.3.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react-swc": "^3.5.0",
    "dotenv": "^16.3.1",
    "eslint": "^8.53.0",
